generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id String @id @default(cuid())

  name String

  email String?

  phone String

  bookings Booking[]

  createdAt DateTime @default(now())
}

model Booking {
  id String @id @default(cuid())

  customerId String

  customer Customer @relation(fields: [customerId], references: [id])

  serviceType String

  status String @default("pending")

  returnDate DateTime?

  duration String?

  requirements String?
  
  vehicleId String?

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  routeId String?

  route Route? @relation(fields: [routeId], references: [id])

  totalAmount Float?

  paymentType String? @default("later")

  amountPaid Float? @default(0)

  paymentScreenshot String?

  paymentStatus String? @default("pending")

  taxi TaxiBooking?

  airport AirportTransfer?

  tour TourBooking?

  selfDrive SelfDriveBooking?

  luxury LuxuryBooking?

  wedding WeddingBooking?

  tempo TempoBooking?

  createdAt DateTime @default(now())
}

model WeddingBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  luxuryCarId String

  luxuryCar LuxuryCar @relation(fields: [luxuryCarId], references: [id])

  pickup String

  venue String

  weddingDate DateTime

  guests Int

  carsRequired Int

  decoration String?

  requirements String?
}

model LuxuryBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  luxuryCarId String

  luxuryCar LuxuryCar @relation(fields: [luxuryCarId], references: [id])

  pickup String

  destination String

  eventDate DateTime

  hours String

  eventType String

  requirements String?
}

model TaxiBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  rideMode String

  pickup String

  drop String?

  vehicle String

  passengers String?

  distance Float?

  travelDate DateTime?

  pickupTime String?

  returnTime String?

  requirements  String?
}

model AirportTransfer {
  id String @id @default(cuid())
  bookingId String @unique
  booking Booking @relation(fields: [bookingId], references: [id])

  pickup String
  airport String
  terminal String?

  cityId String?
  city   AirportCity? @relation(fields: [cityId], references: [id])
  direction String @default("TO_AIRPORT")

  travelDate DateTime
  pickupTime String
  vehicle String
  passengers Int
  suitcases Int
  handbags Int
}

model TourBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  pickupCity String

  destination String

  route String

  pickupAddress String

  travelDate DateTime?   // ← add this

  requirements String?
}

model SelfDriveBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  vehicleId String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  pickupDate DateTime

  returnDate DateTime

  license String

  requirements String?
}

model TempoBooking {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id])

  vehicleId String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  pickup String

  destination String

  travelDate DateTime
  passengers Int
  suitcaseCount Int @default(0)

  tripType String

  requirements String?
}

model Vehicle {
  id String @id @default(cuid())

  name String
  category String

  price Float

  imageUrl String?

  available Boolean @default(true)

  /* EXISTING RELATIONS */
  luxuryCar LuxuryCar?
  selfDriveBookings SelfDriveBooking[]
  tempoBookings TempoBooking[]

  /* ---------------- NEW FIELDS ---------------- */

  // SELF DRIVE SPECIFICATIONS (ONLY FOR SELF DRIVE CATEGORY)
  fuelType String?        // Diesel / Petrol / Electric
  transmission String?    // Manual / Automatic
  seats Int?              // 7, 5 etc.
  modelYear Int?          // 2025

  rentalPerDay Float?     // ₹ per day

  description String?
  /* ---------------- FLEET TYPE CONTROL ---------------- */
  isTaxiFleet Boolean @default(true)
  isSelfDrive Boolean @default(false)

  // COMMON FOR NON-LUXURY VEHICLES
  passengerCapacity Int?
  suitcaseCapacity Int?

  createdAt DateTime @default(now())
  
  bookings Booking[]
}

model PaymentSettings {
  id String @id @default(cuid())
  qrCodeImage String
  upiId String?
  updatedAt DateTime @updatedAt
}

model TourLocation {

  id String @id @default(cuid())

  name String @unique

  imageUrl String?

  canPickup Boolean @default(false)

  canDrop Boolean @default(false)


  active Boolean @default(true)


  createdAt DateTime @default(now())

}

model LuxuryCar {
  id String @id @default(cuid())

  name String

  slug String @unique

  image String

  category String

  description String

  features String[]

  vehicleId String @unique

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  bookings LuxuryBooking[]

  weddingBookings WeddingBooking[]

  createdAt DateTime @default(now())
}

model Feedback {
  id String @id @default(cuid())

  customerName String
  travelDate   DateTime?
  route        String?

  satisfaction String

  vehicleRating Int
  supportRating Int

  driverExperience String

  comments String?

  recommend Boolean

  showOnWebsite Boolean @default(false)

  createdAt DateTime @default(now())
}

model AdminDevice {
  id String @id @default(cuid())

  name String

  deviceToken String @unique
  fingerprint String @unique

  userAgent String?

  // pending  -> registered, not yet trusted, cannot access /admin
  // approved -> trusted, can access /admin
  // revoked  -> was approved, access has been explicitly pulled
  status String @default("pending")

  // Kept for backward compatibility with any existing code that reads
  // `active` directly. Always kept in sync with status === "approved"
  // by the route handlers — don't write to this field independently.
  active Boolean @default(false)

  lastUsed DateTime?

  invitesCreated AdminDeviceInvite[] @relation("InviteCreatedBy")
  invitesRedeemed AdminDeviceInvite[] @relation("InviteRedeemedBy")

  createdAt DateTime @default(now())
}

model AdminDeviceInvite {
  id String @id @default(cuid())

  code String @unique

  createdByDeviceId String
  createdByDevice   AdminDevice @relation("InviteCreatedBy", fields: [createdByDeviceId], references: [id])

  redeemedByDeviceId String?
  redeemedByDevice   AdminDevice? @relation("InviteRedeemedBy", fields: [redeemedByDeviceId], references: [id])

  expiresAt DateTime
  redeemedAt DateTime?

  createdAt DateTime @default(now())
}


model Route {
  id          String   @id @default(cuid())
  title       String
  from        String?
  to          String?
  category    String   // destination | one_way | local | airport | tour
  baseType    String   // taxi | airport | tour
  image       String?
  active      Boolean  @default(true)

  pricing     RoutePricing[]

  bookings    Booking[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoutePricing {
  id        String  @id @default(cuid())

  routeId   String
  vehicleId String

  price     Int

  route     Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId])
}

model Airport {
  id String @id @default(cuid())
  name String
  shortName String
  image String?
  description String?
  active Boolean @default(true)

  cityPricing AirportCityPricing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model GalleryImage {
  id String @id @default(cuid())
  image String
  description String?
  category String
  order Int @default(0)
  active Boolean @default(true)

  createdAt DateTime @default(now())
}

model Inquiry {
  id String @id @default(cuid())

  name String
  email String
  phone String
  subject String
  message String

  status String @default("new")   // new | contacted | closed

  createdAt DateTime @default(now())
}

model AirportCity {
  id String @id @default(cuid())

  name String @unique

  // Can a customer be picked up FROM this city, traveling TO an airport
  canPickup Boolean @default(true)

  // Can a customer be dropped INTO this city, coming FROM an airport
  canDrop Boolean @default(true)

  active Boolean @default(true)

  pricing AirportCityPricing[]
  transfers AirportTransfer[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AirportCityPricing {
  id String @id @default(cuid())

  airportId String
  cityId    String
  vehicleId String

  // "TO_AIRPORT" | "FROM_AIRPORT" — priced independently since fares differ by direction
  direction String

  price Int

  airport Airport     @relation(fields: [airportId], references: [id], onDelete: Cascade)
  city    AirportCity @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([airportId, cityId, vehicleId, direction])
}