generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id        String   @id @default(cuid())

  name      String
  email     String?
  phone     String

  pickup    String
  drop      String?

  rideType  String
  rideMode  String

  vehicle   String
  distance  Float?
  days      Int?

  amount    Float

  status    String   @default("pending")

  createdAt DateTime @default(now())
}